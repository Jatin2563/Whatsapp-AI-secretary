    {
      "parameters": {
        "jsCode": "const chatId = $input.item.json.body.senderData.chatId;\nconst now = Date.now();\nconst windowMs = 60000; // 1 minute\nconst maxRequests = 3; // max 3 messages per minute\n\n// Get stored data\nconst key = `rateLimit_${chatId}`;\nconst stored = $getWorkflowStaticData('node');\n\nif (!stored[key]) {\n  stored[key] = { count: 1, startTime: now };\n  return $input.item;\n}\n\nconst elapsed = now - stored[key].startTime;\n\nif (elapsed > windowMs) {\n  // Reset window\n  stored[key] = { count: 1, startTime: now };\n  return $input.item;\n}\n\nif (stored[key].count >= maxRequests) {\n  // Rate limit exceeded\n  throw new Error('RATE_LIMITED');\n}\n\nstored[key].count++;\nreturn $input.item;"
      },
